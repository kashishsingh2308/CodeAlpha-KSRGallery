rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'userId', 'createdAt'])
        && data.keys().size() == 3
        && data.name is string && data.name.size() > 0 && data.name.size() <= 50
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidGalleryImage(data) {
      return data.keys().hasAll(['url', 'category', 'title', 'userId', 'createdAt']) 
        && data.keys().size() <= 7 // Allow description and userEmail as optional
        && data.url is string && data.url.size() <= 1048576 // 1MB limit for Data URIs
        && data.category is string && data.category.size() > 0
        && data.title is string && data.title.size() <= 100
        && (!('description' in data) || (data.description is string && data.description.size() <= 500))
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    // --- Collections ---
    match /categories/{categoryId} {
      allow list: if true; // Reading is allowed for sharing, but queries must filter by userId
      allow get: if true;
      allow create: if isSignedIn() && isValidCategory(incoming());
      allow delete: if isOwner(existing().userId);
    }

    match /images/{imageId} {
      allow list: if true; // Reading is allowed for sharing, but queries must filter by userId
      allow get: if true;

      allow create: if isSignedIn() && isValidGalleryImage(incoming());
      
      allow update: if isOwner(existing().userId) 
        && isValidGalleryImage(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;

      allow delete: if isOwner(existing().userId);
    }
    
    match /test/connection {
      allow get: if true;
    }
  }
}
